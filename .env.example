# Finance Agent Environment Configuration Template
# Copy to .env and fill in your values

# Feishu/Lark — Bot Application Credentials
# Create at: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenBB / Financial Data API Keys
OPENBB_FMP_API_KEY=
OPENBB_FRED_API_KEY=

# Feishu Bot — Whitelisted User open_id
# Get via: lark-cli auth login && lark-cli contact +me
ALLOWED_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
